section .data
msg1 db "count of positive numbers: "
len1 equ $-msg1
msg2 db "count of negative numbers: "
len2 equ $-msg2
array db 10,12,-21,-12,-19,-34,41   ; 7 numbers: 4 positive, 3 negative

%macro print 2
mov rax,01
mov rdi,01
mov rsi,%1
mov rdx,%2
syscall
%endmacro

section .bss
count resb 1
pcount resb 1
ncount resb 1
totalcount resb 1

section .text
global _start

_start:
mov byte[count],07
mov byte[pcount],00
mov byte[ncount],00

mov rsi,array
up:
mov al,[rsi]          ; Load byte from array
test al,al            ; **FIX: Use TEST to set sign flag properly**
js neg                ; Jump if sign flag set (negative)
inc byte[pcount]      ; Positive count
jmp down
neg:
inc byte[ncount]      ; Negative count

down:
inc rsi               ; Next array element
dec byte[count]
jnz up

print msg1,len1
mov bh,[pcount]
call disp

print msg2,len2
mov bh,[ncount]
call disp

mov rax,60
mov rdi,0
syscall

disp:
mov byte[count],2

loop_label:
rol bh,04
mov al,bh
and al,0fh
cmp al,09
jbe l1
add al,07h
l1: add al,30h
mov [totalcount],al
print totalcount,1
dec byte[count]
jnz loop_label
ret
