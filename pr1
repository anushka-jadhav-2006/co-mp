section .data
    msg1 db 10,13,"enter 5 64 bit number",10
    len1 equ $-msg1

    msg2 db 10,13,"entered 5 64 bit number",10
    len2 equ $-msg2

section .bss
    array   resb 200        
    counter resb 1

section .text
    global _start

_start:

;  display msg1 
    mov rax, 1              
    mov rdi, 1              
    mov rsi, msg1
    mov rdx, len1
    syscall

;  accept input 
    mov byte [counter], 5
    xor rbx, rbx            
loop1:
    mov rax, 0             
    mov rdi, 0              
    lea rsi, [array + rbx]
    mov rdx, 17             
    syscall

    add rbx, 17
    dec byte [counter]
    jnz loop1

;  display msg2 
    mov rax, 1
    mov rdi, 1
    mov rsi, msg2
    mov rdx, len2
    syscall

    mov byte [counter], 5
    xor rbx, rbx

loop2:
    mov rax, 1              ; sys_write
    mov rdi, 1
    lea rsi, [array + rbx]
    mov rdx, 17
    syscall

    add rbx, 17
    dec byte [counter]
    jnz loop2

;  exit 
    mov rax, 60             ; sys_exit
    xor rdi, rdi
    syscall
